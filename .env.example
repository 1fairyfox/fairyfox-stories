# Copy this file to `.env` and fill in your key. `.env` is gitignored — never committed.
# Used by LOCAL tooling only (scripts/) to draft prose and generate cover/chapter art via
# the OpenAI API. The published site calls no API at read time and stays static.

# OpenAI API key (writing service + image generation).
OPENAI_API_KEY=

# Optional model overrides (sensible defaults are used if unset).
# WRITER_MODEL=gpt-4o
# IMAGE_MODEL=gpt-image-1
